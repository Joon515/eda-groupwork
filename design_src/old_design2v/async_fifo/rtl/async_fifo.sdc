# ----------------------------------------------------------------------
# 定义变量
# ----------------------------------------------------------------------
set CLK_A_NAME "clk_wr"
set CLK_A_PERIOD "5.000"

set CLK_B_NAME "clk_rd"
set CLK_B_PERIOD "20.000"

# ----------------------------------------------------------------------
# 定义源时钟
# ----------------------------------------------------------------------
create_clock -name $CLK_A_NAME -period $CLK_A_PERIOD [get_ports $CLK_A_NAME]

# ----------------------------------------------------------------------
# 定义目标时钟
# ----------------------------------------------------------------------
create_clock -name $CLK_B_NAME -period $CLK_B_PERIOD [get_ports $CLK_B_NAME]

# ----------------------------------------------------------------------
# 声明两个时钟是完全异步的
# ----------------------------------------------------------------------
set_clock_groups -asynchronous -group $CLK_A_NAME -group $CLK_B_NAME

# ----------------------------------------------------------------------
# 时钟不确定性
# ----------------------------------------------------------------------
derive_clock_uncertainty